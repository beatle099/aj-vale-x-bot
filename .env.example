# Safety defaults
DRY_RUN=true
AUTO_POST=false

# Local state
HISTORY_PATH=post_history.json
SIMILARITY_THRESHOLD=0.82
LOG_LEVEL=INFO

# Optional webhook
HOST=127.0.0.1
PORT=8000

# Optional X API posting. Posting remains disabled unless AUTO_POST=true and DRY_RUN=false.
# OAuth 1.0a user-context credentials are the recommended posting path.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Optional fallback for OAuth 2.0 user-context bearer tokens with tweet.write scope.
X_BEARER_TOKEN=
